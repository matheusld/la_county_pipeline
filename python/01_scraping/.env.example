# Required for: build_openai_batch_requests_v5.py, run_openai_batch_multi.py,
#               parse_openai_batch_results_v5.py
# Steps 1-4 (scraping and extraction) need no API key.
#
# Copy to .env and load before running batch steps:
#   Windows (PowerShell): foreach ($line in Get-Content .env) { if ($line -notmatch '^#') { $parts = $line -split '=', 2; [System.Environment]::SetEnvironmentVariable($parts[0], $parts[1]) } }
#   Mac/Linux:            export $(grep -v '^#' .env | xargs)

OPENAI_API_KEY=your-openai-api-key-here
