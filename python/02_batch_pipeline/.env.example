# Required for: S06_GPT and S06_CLAUDE only.
# Stages S01-S05, S07, S08, S09 need no API keys.
#
# Copy to .env and load before running:
#   Windows (PowerShell):
#     foreach ($line in Get-Content .env) { if ($line -notmatch '^#') { $parts = $line -split '=', 2; [System.Environment]::SetEnvironmentVariable($parts[0], $parts[1]) } }
#   Mac/Linux:
#     export $(grep -v '^#' .env | xargs)
#
# OpenAI key: https://platform.openai.com/api-keys
# Anthropic key: https://console.anthropic.com/settings/keys
#
# Set a monthly spend limit in both accounts before running S06_GPT and S06_CLAUDE.
# The pipeline tracks cost in outputs/cost_log.jsonl.

OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
