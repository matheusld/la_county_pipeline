# Copy this file to .env and fill in your keys before running either phase.
#
#   Windows:   copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# Then load it into your shell session:
#   Windows (PowerShell):
#     foreach ($line in Get-Content .env) { if ($line -notmatch '^#') { $parts = $line -split '=', 2; [System.Environment]::SetEnvironmentVariable($parts[0], $parts[1]) } }
#   Mac/Linux:
#     export $(grep -v '^#' .env | xargs)
#
# OpenAI key:   https://platform.openai.com/api-keys
# Anthropic key: https://console.anthropic.com/settings/keys
# Recommended: set a monthly spend limit in both account dashboards.

# --- Phase 1 (scraping) and Phase 2 S06_GPT ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Phase 2 S06_CLAUDE only ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
